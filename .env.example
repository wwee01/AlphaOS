# ============================================================================
# AlphaOS v1 — example environment configuration
# Copy to `.env` and fill in. NEVER commit a real `.env`.
#
# v1 posture: ONE real market-data path (Alpaca/IEX), NO news (no-news baseline),
# execution is simulated internally, real money is unreachable. In mock/offline
# mode the app runs with ZERO external keys.
# ============================================================================

# --- AI: OpenAI is the primary runtime engine -------------------------------
OPENAI_API_KEY=
OPENAI_PRIMARY_MODEL=gpt-4o-mini
OPENAI_REVIEW_MODEL=gpt-4o-mini

# --- AI: Claude is an OPTIONAL, manual-only second-opinion reviewer ----------
# If empty, the "Request Claude second opinion" button is disabled.
ANTHROPIC_API_KEY=
CLAUDE_REVIEW_MODEL=claude-sonnet-4-6

# --- Market data: Alpaca is the SOLE active provider in v1 (free IEX tier) ---
# DATA_PROVIDER must be 'alpaca' in v1 (anything else fails fast on startup).
DATA_PROVIDER=alpaca
MARKET_DATA_FEED=iex
# Live market data reuses the Alpaca credentials below. Missing creds in live
# mode do NOT silently fall back to any other source — data is blocked instead.

# --- News: OFF in v1 (no-news momentum baseline) ----------------------------
# NEWS_ENABLED=true is unsupported in v1 and fails fast on startup.
NEWS_ENABLED=false
NEWS_PROVIDER=disabled

# --- Broker / data credentials: Alpaca PAPER ONLY ---------------------------
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Execution -------------------------------------------------------------
# simulated_internal : fills are simulated internally (default; works offline).
# alpaca_paper       : place REAL broker-native bracket orders on the Alpaca
#                      PAPER API (requires ALPHAOS_MODE=paper + Alpaca paper
#                      creds; still NO real money). A fill is only ever labelled
#                      alpaca_paper when it comes from the real Alpaca paper API.
EXECUTION_PROVIDER=simulated_internal
ALLOW_REAL_ORDERS=false
REQUIRE_MANUAL_APPROVAL=true

# --- Notifications (optional) ------------------------------------------------
NTFY_TOPIC=

# --- Runtime safety switches ------------------------------------------------
# mock | paper   (shadow/research are recognized-but-inactive stubs; live is not reachable)
ALPHAOS_MODE=mock
# manual | auto  (auto also requires REQUIRE_MANUAL_APPROVAL=false to take effect)
APPROVAL_MODE=manual
# MUST be exactly "false" in v1. Any other value blocks all order placement.
REAL_TRADING_ENABLED=false
# Explicit offline/mock data toggles (mock mode is always explicit + labelled).
RUN_MODE=
OFFLINE_MODE=false

# --- Risk limits (paper) ----------------------------------------------------
MAX_RISK_PER_TRADE_PCT=0.01
MAX_PAPER_TRADES_PER_DAY=5
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_PCT=0.03
PAPER_EQUITY=100000
MAX_AUTO_APPROVALS_PER_DAY=1
MAX_SPREAD_PCT=0.01
MIN_DOLLAR_VOLUME=2000000

# --- Trade sizing (stop distance / target reward:risk) ----------------------
# Stop is STOP_LOSS_PCT below entry (long) / above (short). Target sits at that
# distance scaled by TARGET_REWARD_RISK, so the target move = STOP_LOSS_PCT x RR
# (default 0.03 x 1.5 = 4.5%). These drive the mock baseline; for the live
# OpenAI engine the model sets levels but MIN_REWARD_RISK still clamps them.
STOP_LOSS_PCT=0.03                 # stop distance as a fraction of entry (0-0.5)
TARGET_REWARD_RISK=1.5             # target reward:risk (was an implicit 2.0)
MIN_REWARD_RISK=1.2               # reject any proposal below this reward:risk

# --- Data freshness gate (Alpaca/IEX aware) ---------------------------------
MAX_QUOTE_AGE_SECONDS_RTH=60
MAX_BAR_AGE_SECONDS_RTH=180
MAX_QUOTE_AGE_SECONDS_PREMARKET=300
MAX_BAR_AGE_SECONDS_PREMARKET=600
MAX_PRICE_DRIFT_BPS_SINCE_PROPOSAL=50
# Legacy single-age knob (kept for back-compat; the per-session knobs above win).
MAX_DATA_AGE_SECONDS=120

# --- Cost model (realistic-cost accounting; net P&L = gross - costs) ---------
COST_COMMISSION_PER_SHARE=0.0     # Alpaca US equities: $0
COST_MIN_COMMISSION=0.0           # per-fill floor
COST_SLIPPAGE_BPS=1.0             # per side (entry + exit)

# --- Storage / dev ----------------------------------------------------------
ALPHAOS_DB_PATH=data/alphaos.db
ALPHAOS_JSONL_MIRROR=false

# --- Deferred providers — NOT used in v1 (see connectors/deferred/DEFERRED.md) ---
# MASSIVE_API_KEY=        # deferred — not used in v1
# BENZINGA_API_KEY=       # deferred — not used in v1
