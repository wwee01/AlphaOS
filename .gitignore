# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Environment / secrets — NEVER commit real secrets
.env
.env.local
*.key

# AlphaOS runtime artifacts
data/*.db
data/*.sqlite
data/*.sqlite3
data/backup_status.json
*.enc
*.db
*.sqlite
*.sqlite3
journal_*.jsonl
alphaos.log

# Test / tooling
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
# This repo's CI/tooling uses pip, not uv -- uv.lock is incidental local
# byproduct of `uv run`, not a committed dependency source of truth.
uv.lock

# OS / editor
.DS_Store
.idea/
.vscode/

# ND-1 console (React/Vite) -- source only; build output and deps are
# reproducible from console/package.json + `npm run build`. (dist/ above
# already matches console/dist/ at any depth; listed explicitly too so this
# is unambiguous for anyone grepping .gitignore for "console".)
console/node_modules/
console/dist/
